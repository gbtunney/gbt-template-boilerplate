{
    "name": "@snailicid3/template-example-package",
    "version": "0.0.0",
    "private": false,
    "description": "Example monorepo package",
    "scripts": {
        "build:nx": "nx run $npm_package_name:build",
        "test:nx": "nx run $npm_package_name:test",
        "clean:nx": "nx run $npm_package_name:clean",
        "dev:nx": "nx run $npm_package_name:dev",
        "test:coverage": "vitest run --coverage"
    },
    "nx": {
        "targets": {
            "dev": {},
            "dev:ts": {},
            "dev:tsdown": {},
            "dev:vite": {},
            "check:ts": {},
            "build:tsdown": {},
            "build:ts": {},
            "build": {},
            "test": {},
            "test:watch": {},
            "lint": {},
            "fix": {},
            "clean": {},
            "clean:ts": {},
            "clean:build": {}
        }
    },
    "dependencies": {
        "@snailicid3/utils": "^0.0.4"
    },
    "devDependencies": {
        "@snailicid3/build-config": "^0.0.4",
        "@snailicid3/config": "^0.0.4",
        "@types/node": "^25.9.0",
        "cross-var": "^1.1.0",
        "tsdown": "^0.22.0",
        "typescript": "^6.0.3",
        "vitest": "^4.1.6"
    },
    "type": "module",
    "author": {
        "name": "Gillian Tunney",
        "email": "gbtunney@mac.com"
    },
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/gbtunney/gbt-template-boilerplate",
        "directory": "packages/example-package"
    },
    "homepage": "https://github.com/gbtunney/snailicid3#README",
    "packageManager": "pnpm@10.9.0",
    "files": [
        "CHANGELOG.md",
        "dist",
        "types"
    ],
    "keywords": [
        "boilerplate"
    ],
    "main": "./dist/index.cjs",
    "module": "./dist/index.mjs",
    "types": "./dist/index.d.cts",
    "exports": {
        ".": {
            "import": "./dist/index.mjs",
            "require": "./dist/index.cjs"
        },
        "./package.json": "./package.json"
    }
}
