{
    "name": "@gbt/template-example-react",
    "version": "0.0.0",
    "private": true,
    "description": "Example child package in monorepo",
    "scripts": {
        "build:nx": "nx run $npm_package_name:build",
        "build:storybook:nx": "nx run $npm_package_name:build:storybook",
        "dev:nx": "nx run $npm_package_name:dev",
        "dev:storybook": "pnpm exec nx run -p $npm_package_name -t build:ts check:ts && pnpm exec storybook dev -p 6006",
        "test:nx": "nx run $npm_package_name:test",
        "clean:nx": "nx run $npm_package_name:clean",
        "chromatic:nx": "nx run $npm_package_name:chromatic",
        "test:chromatic": "pnpm exec dotenv -e .env.local -- pnpm chromatic:nx"
    },
    "nx": {
        "targets": {
            "dev": {},
            "dev:ts": {},
            "dev:tsdown": {},
            "dev:vite": {},
            "check:ts": {},
            "build:tsdown": {},
            "build:ts": {},
            "build": {},
            "build:storybook": {},
            "chromatic": {},
            "test": {},
            "test:watch": {},
            "lint": {},
            "fix": {},
            "clean": {},
            "clean:ts": {},
            "clean:build": {}
        }
    },
    "dependencies": {
        "@snailicid3/utils": "^0.0.5",
        "@vitejs/plugin-react": "^6.0.3",
        "react": "^19.2.7",
        "react-dom": "^19.2.7"
    },
    "devDependencies": {
        "@chromatic-com/storybook": "^5.2.1",
        "@snailicid3/build-config": "^0.0.8",
        "@snailicid3/config": "^0.1.3",
        "@storybook/addon-a11y": "^10.5.0",
        "@storybook/addon-docs": "^10.5.0",
        "@storybook/addon-vitest": "^10.5.0",
        "@storybook/react-vite": "^10.5.0",
        "@testing-library/jest-dom": "^6.9.1",
        "@testing-library/react": "^16.3.2",
        "@tsdown/css": "^0.22.8",
        "@types/node": "^26.0.1",
        "@types/react": "^19.2.17",
        "@types/react-dom": "^19.2.3",
        "@vitest/coverage-v8": "4.1.10",
        "chromatic": "^18.0.1",
        "cross-var": "^1.1.0",
        "dotenv-cli": "^11.0.0",
        "jsdom": "^29.1.1",
        "storybook": "^10.5.0",
        "tsdown": "^0.22.3",
        "typescript": "^6.0.3",
        "vitest": "^4.1.9"
    },
    "type": "module",
    "author": {
        "name": "Gillian Tunney",
        "email": "gbtunney@mac.com"
    },
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/OWNER/REPOSITORY",
        "directory": "packages/example-package"
    },
    "packageManager": "pnpm@10.9.0",
    "files": [
        "CHANGELOG.md",
        "dist",
        "types"
    ],
    "keywords": [
        "boilerplate"
    ],
    "types": "./dist/index.d.cts",
    "exports": {
        ".": "./dist/index.js",
        "./package.json": "./package.json",
        "./style.css": "./dist/style.css"
    }
}
