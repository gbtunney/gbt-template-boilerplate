{
    "tasksRunnerOptions": {
        "default": {
            "runner": "nx/tasks-runners/default",
            "options": {
                "cacheableOperations": ["build", "test"]
            }
        }
    },
    "targetDefaults": {
        "build": {
            "dependsOn": ["^build"]
        },
        "test": {
            "dependsOn": ["build", "^test"]
        },
        "docs:build": {
            "dependsOn": ["build", "test", "^docs:build"]
        }
    },
    "analytics": true
}
