{
    "name": "@gbt/root",
    "version": "0.0.0",
    "private": true,
    "description": "Boilerplate for monorepo root",
    "scripts": {
        "\n========== COMMIT >> ==========": "",
        "commit": "pnpm run commit:before && pnpm commit:cz",
        "commit:cz": "pnpm exec git-cz",
        "commit:before": "pnpm build:self && pnpm run lint:staged",
        "lint:staged": "pnpm exec lint-staged --relative --debug",
        "commit:direct": "git commit --no-verify -m",
        "lint:all": "pnpm fix && pnpm build",
        "repo:status": "pnpm exec ./scripts/ensure-clean.ts",
        "\n========== INSPECT >>==========": "",
        "inspect:nx": "pnpm nx:graph",
        "inspect:lint": "pnpm exec eslint-config-inspector",
        "inspect:vitest": "pnpm exec vitest --ui",
        "\n========== BUILD >> ==========": "",
        "build": "pnpm build:self && pnpm nx:build",
        "build:self": "pnpm exec tsc --build",
        "build:self:nx": "pnpm exec nx run root:build:self",
        "nx:build": "pnpm exec nx run-many -t build",
        "nx:build:bk": "pnpm exec nx run-many -t build --exclude=root",
        "nx:build:all": "pnpm exec nx run-many --target=build --all",
        "build:all": "pnpm workspace build",
        "nx:test:ts": "pnpm exec nx run-many -t build:ts",
        "\n========== TEST >> ==========": "",
        "test": "pnpm nx:test",
        "test:coverage": "pnpm -r --if-present --filter=./packages/* run test:coverage",
        "nx:test": "pnpm exec nx run-many --target=test",
        "\n========== NX >> ==========": "",
        "nx:graph": "pnpm nx graph",
        "nx:affected": "nx affected --target=build",
        "nx:reset": "pnpm exec nx reset",
        "\n========== LIFECYCLE >> ==========": "",
        "start": "pnpm install && pnpm build",
        "uninstall": "./scripts/uninstall.sh",
        "uninstall:hard": "pnpm run uninstall && pnpm store prune",
        "reset": "pnpm run uninstall && pnpm install",
        "pre:commit": "echo '\n===\n>> Todo:: enable `pnpm exec lint-staged --debug`'",
        "prepare": "husky",
        "postinstall": "echo '\n=== >> Success:: Install complete.'",
        "prune": "pnpm store prune",
        "workspace": "pnpm -r",
        "\n========== PUBLISH >> ==========": "",
        "release": "pnpm run prerelease && pnpm changeset",
        "prerelease": "pnpm run build && pnpm run fix && pnpm run check && pnpm test",
        "\n========== WORKFLOW >> ==========": "",
        "workflow:archive": "pnpm install && open /Applications/Docker.app && cross-var pnpm exec gh act --workflows  ./.github/workflows/workflow-build.yml --reuse",
        "registry:start": "pnpm exec verdaccio",
        "\n========== CODE STYLE >> ==========": "",
        "prettier": "cross-var prettier {*,**/*}.{xml,ts,js,cts,cjs,mts,mjs,tsx,jsx,sh,html,json,yaml,yml,graphql,md} ./.husky/* --ignore-path ./.gitignore --no-error-on-unmatched-pattern --config ./prettier.config.js",
        "lint": "cross-var eslint -c $npm_package_config_eslint_config --debug",
        "lint:md": "pnpm exec markdownlint-cli2 '{./*,./**/*}.md' '#**/{.history,node_modules,.changeset,docs}/**' '#api/gbt-tuya-device/**/*' '#packages/cli-template/templates/**/*'",
        "lint:md:warn": "pnpm exec markdownlint-cli2 '{./*,./**/*}.md' '#**/{.history,node_modules,.changeset,docs}/**' '#api/gbt-tuya-device/**/*' '#packages/cli-template/templates/**/*' || true",
        "\n========== CHECK >> ==========": "",
        "check": "pnpm build:self && pnpm check:self",
        "check:md": "pnpm run lint:md:warn",
        "check:self": "pnpm lint && pnpm prettier --check",
        "prettier:write": "pnpm prettier --write",
        "\n========== FIX >> ==========": "",
        "fix": "pnpm build:self && pnpm fix:self",
        "fix:md": "pnpm run lint:md:warn --fix",
        "fix:self": "pnpm prettier --write && pnpm lint --fix && pnpm fix:md",
        "\n========== CLEAN >> ==========": "",
        "clean": "pnpm clean:self && pnpm clean:all",
        "clean:self": "pnpm exec tsc --build --clean",
        "clean:all": "pnpm workspace  clean"
    },
    "dependencies": {
        "@gbt/root": "link:"
    },
    "devDependencies": {
        "@changesets/cli": "^2.29.8",
        "@commitlint/cli": "^20.4.1",
        "@commitlint/config-conventional": "^20.4.1",
        "@commitlint/cz-commitlint": "^20.3.1",
        "@commitlint/types": "^20.4.0",
        "@eslint/config-inspector": "^1.4.2",
        "@prettier/plugin-php": "^0.24.0",
        "@prettier/plugin-xml": "^3.4.2",
        "@snailicide/build-config": "^1.4.4",
        "@types/node": "^25.2.2",
        "@types/shelljs": "^0.10.0",
        "commitizen": "^4.3.1",
        "cross-var": "^1.1.0",
        "dotenv-cli": "^11.0.0",
        "eslint": "^9.25.1",
        "eslint-plugin-react-hooks": "^7.0.1",
        "eslint-plugin-react-refresh": "^0.4.26",
        "eslint-plugin-storybook": "^10.2.8",
        "husky": "^9.1.7",
        "lint-staged": "^16.2.7",
        "markdownlint-cli2": "^0.20.0",
        "nx": "^22.5.1",
        "prettier": "^3.8.1",
        "prettier-plugin-jsdoc": "^1.8.0",
        "prettier-plugin-pkg": "^0.21.2",
        "prettier-plugin-sh": "^0.18.0",
        "remark-toc": "^9.0.0",
        "rollup-plugin-dts": "^6.3.0",
        "rollup-plugin-esbuild": "^6.2.1",
        "tsx": "^4.21.0",
        "typedoc-plugin-markdown": "^4.10.0",
        "typedoc-plugin-remark": "^2.0.1",
        "typedoc-plugin-zod": "^1.4.3",
        "typescript": "^5.9.3",
        "typescript-eslint": "^8.54.0",
        "unified-prettier": "^2.0.1",
        "verdaccio": "^6.2.5",
        "vitepress": "^1.6.4",
        "vitest": "^4.0.18"
    },
    "type": "module",
    "author": {
        "name": "Gillian Tunney",
        "email": "gbtunney@mac.com"
    },
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/gbtunney/gbt-boilerplate"
    },
    "homepage": "https://github.com/gbtunney/gbt-boilerplate",
    "packageManager": "pnpm@10.30.2+sha512.36cdc707e7b7940a988c9c1ecf88d084f8514b5c3f085f53a2e244c2921d3b2545bc20dd4ebe1fc245feec463bb298aecea7a63ed1f7680b877dc6379d8d0cb4",
    "engines": {
        "node": ">=20.x"
    },
    "files": [
        "CHANGELOG.md",
        "dist",
        "types"
    ],
    "keywords": [
        "boilerplate"
    ],
    "config": {
        "prettier": {
            "extensions": "ts,js,cjs,mjs,cts,mts,sh,html,json,yaml,yml,graphql,md",
            "path": "*,**/*",
            "config": "prettier.config.js"
        },
        "eslint": {
            "config": "eslint.config.js"
        },
        "commitizen": {
            "path": "@commitlint/cz-commitlint"
        }
    },
    "pnpm": {
        "patchedDependencies": {
            "browserslist-generator@2.3.0": "patches/browserslist-generator@2.3.0.patch"
        }
    }
}
