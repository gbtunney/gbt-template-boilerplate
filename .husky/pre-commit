#!/usr/bin/env bash
# filepath: /Users/gilliantunney/gbt-template-boilerplate/.husky/pre-commit
set -euo pipefail

. "$(dirname -- "$0")/hook-lib.sh"

BRANCH="$(get_branch)"
PROTECTED_BRANCHES="^(master|main)$"
LINT_MODE="LINT_STAGED" # other values: LINT_ALL | DISABLED

# Allowed: A-Z a-z 0-9 space . _ - + @ /   (blocks unicode like —)
BAD_FILENAME_RE='[^A-Za-z0-9._/@ +\-]'

# Force LINT_ALL on development branch
if [ "$BRANCH" = "development" ]; then
    LINT_MODE="LINT_ALL"
fi

hook_banner "pre-commit" "shell=${SHELL:-unknown}" "branch=$BRANCH" "lint_mode=$LINT_MODE"

# Centralized checks (shared with prepare-commit-msg)
assert_not_protected_branch "$BRANCH" "$PROTECTED_BRANCHES"
assert_valid_branch_name "$BRANCH"
assert_no_bad_chars_in_staged_filenames "$BAD_FILENAME_RE"

if [ "$LINT_MODE" = "DISABLED" ]; then
    exit 0
fi

if [ "$LINT_MODE" = "LINT_ALL" ]; then
    printf "\nRunning full lint/format (LINT_ALL)...\n\n"
    pnpm lint:all
    git add -A
    exit 0
fi

# LINT_STAGED:
# Intentionally do not run lint-staged here; commit flow handles it elsewhere.
printf "\nLINT_STAGED: hook checks passed.\n\n"
exit 0