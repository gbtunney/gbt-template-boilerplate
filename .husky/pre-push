#!/usr/bin/env bash
# filepath: /Users/gilliantunney/gbt-template-boilerplate/.husky/pre-push
set -euo pipefail

. "$(dirname -- "$0")/hook-lib.sh"

BRANCH="$(get_branch)"
PROTECTED_BRANCHES="^(master|main)$"

hook_banner "pre-push" "shell=${SHELL:-unknown}" "branch=$BRANCH"

# Block pushes on protected branches
assert_not_protected_branch "$BRANCH" "$PROTECTED_BRANCHES"

# Optional: enforce naming policy on branches you push
assert_valid_branch_name "$BRANCH"

exit 0